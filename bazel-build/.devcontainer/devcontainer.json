{
    "name": "ROS 2 Humble Bazel Sandbox",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-iot.vscode-ros",
                "ms-vscode.cpptools",
                "bazelbuild.vscode-bazel"
            ]
        }
    },
    "remoteUser": "rosuser",
    "postCreateCommand": "sudo chown -R rosuser:rosuser /workspaces/sandbox/bazel-build && echo 'source /opt/ros/humble/setup.bash' >> ~/.bashrc"
}
