{
    "name": "ROS 2 Humble (RViz & Gazebo)",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "runArgs": [
        "--net=host",
        "--ipc=host",
        "--cap-add=SYS_PTRACE",
        "--security-opt=seccomp=unconfined",
        "-e", "DISPLAY=${localEnv:DISPLAY}",
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-iot.vscode-ros",
                "ms-vscode.cpptools",
                "ms-python.python",
                "redhat.vscode-yaml"
            ]
        }
    },
    "postCreateCommand": "sudo apt-get update && rosdep update",
    "remoteUser": "rosuser"
}
